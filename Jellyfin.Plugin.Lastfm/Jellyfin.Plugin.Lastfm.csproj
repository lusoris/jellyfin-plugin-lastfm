<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyVersion>10.11.6.1</AssemblyVersion>
    <FileVersion>10.11.6.1</FileVersion>
    <Version>10.11.6.1</Version>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Strict code quality settings -->
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningLevel>9999</WarningLevel>
    <!--
      Suppressed warnings:
      CA1002: Don't expose List<T> - not practical for JSON DTOs
      CA1056: URI properties should be System.Uri - Last.fm returns strings
      CA1711: Don't suffix with EventHandler/Queue - intentional naming
      CA1805: Don't initialize with default value - clearer code
      CA1819: Properties shouldn't return arrays - needed for config
      CA1826: Use indexer instead of First() - minor perf
      CA1860: Prefer Count comparison - .Any() is more readable
      CA2227: Collection properties should be read only - JSON deserialization needs setters
      CA5351: MD5 is broken - Required by Last.fm API, not used for security
    -->
    <NoWarn>CA1002;CA1056;CA1711;CA1805;CA1819;CA1826;CA1860;CA2227;CA5351</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Configuration\configPage.html" />
    <EmbeddedResource Include="Pages\recommendations.html" />
    <EmbeddedResource Include="Pages\statistics.html" />
  </ItemGroup>

  <ItemGroup>
    <!-- Jellyfin packages: MUST exclude runtime assets to prevent DLL conflicts -->
    <PackageReference Include="Jellyfin.Controller" Version="10.*-*">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Lastfm.Scrobbler.Core\Lastfm.Scrobbler.Core.csproj" />
    <ProjectReference Include="..\Lastfm.Scrobbler.Abstractions\Lastfm.Scrobbler.Abstractions.csproj" />
  </ItemGroup>

</Project>
